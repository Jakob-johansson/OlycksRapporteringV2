<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OlycksRapporteringV2.MAUI.MainPage">

    <ScrollView>
        <VerticalStackLayout
          Padding="30,0"
          Spacing="25">
            <Image
              Source="dotnet_bot.png"
              HeightRequest="185"
              Aspect="AspectFit"
              SemanticProperties.Description="dot net bot in a submarine number ten" />

            <Label
              Text="Välkommen till Olycksrapporteraren!"
             
              
              
              
              Style="{StaticResource Headline}"
              SemanticProperties.HeadingLevel="Level1" />

            <Label
              Text="Vänligen logga in eller skapa konto för att forsätta!"
              Style="{StaticResource SubHeadline}"
              SemanticProperties.HeadingLevel="Level2"></Label>

            <Button
              Text="Skapa konto"
              Clicked="OnClickedGoToCreateAccountPage"></Button>
            <Button
              Text="Gå till Login portalen"
              Clicked="OnClickedGoToPortalPage"></Button>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
