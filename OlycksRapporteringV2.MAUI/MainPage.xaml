<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OlycksRapporteringV2.MAUI.MainPage">

    <ScrollView>
        
        <Grid RowDefinitions="*, Auto"
              MinimumHeightRequest="700">

            <VerticalStackLayout Grid.Row="0"
                                 Padding="36,60,36,20"
                                 Spacing="0"
                                 VerticalOptions="Center">

                <!-- Ikon / symbol -->
                <Border WidthRequest="80"
                        HeightRequest="80"
                        HorizontalOptions="Start"
                        Margin="0,0,0,32"
                        BackgroundColor="#E83B3B"
                        StrokeShape="RoundRectangle 20"
                        Stroke="Transparent"
                        >
                  
                    <Label Text=""
                           FontSize="38"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="White"/>
                </Border>
                <Image Source="Logotyp.png"
       HeightRequest="120"
       VerticalOptions="Center"/>
                <!-- Rubrik -->
                <Label Text="Olycks&#10;rapporteraren"
                       FontSize="42"
                       FontAttributes="Bold"
                       TextColor="#F0F0F0"
                       LineHeight="1.1"
                       Margin="0,0,0,16"/>

                <!-- Dekorativ linje -->
                <BoxView HeightRequest="3"
                         WidthRequest="60"
                         Color="#E83B3B"
                         HorizontalOptions="Start"
                         Margin="0,0,0,24"/>

                <!-- Undertext -->
                <Label Text="Rapportera, hantera och följ upp arbetsplatsolyckor enkelt och säkert."
                       FontSize="16"
                       TextColor="#8A8F9E"
                       LineHeight="1.6"
                       Margin="0,0,0,48"/>

                <!-- Primärknapp: Logga in -->
                <Border StrokeShape="RoundRectangle 14"
                        Stroke="Transparent"
                        BackgroundColor="#E83B3B"
                        Margin="0,0,0,14"
                        HeightRequest="56">
                    <Button Text="Gå till inloggning"
                            Clicked="OnClickedGoToPortalPage"
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="16"
                            FontAttributes="Bold"
                            HeightRequest="56"
                            CornerRadius="14"/>
                </Border>

                <!-- Sekundärknapp: Skapa konto -->
                <Border StrokeShape="RoundRectangle 14"
                        Stroke="#2A2D38"
                        BackgroundColor="#1A1D27"
                        HeightRequest="56">
                    <Button Text="Skapa konto"
                            Clicked="OnClickedGoToCreateAccountPage"
                            BackgroundColor="Transparent"
                            TextColor="#C0C4D0"
                            FontSize="16"
                            HeightRequest="56"
                            CornerRadius="14"/>
                </Border>

            </VerticalStackLayout>

           

        </Grid>
    </ScrollView>


</ContentPage>
