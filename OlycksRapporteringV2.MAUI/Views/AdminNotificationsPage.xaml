<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OlycksRapporteringV2.MAUI.Converters"
             xmlns:entities="clr-namespace:OlycksRapporteringV2.Domain.Entities;assembly=OlycksRapporteringV2.Domain"
             x:Class="OlycksRapporteringV2.MAUI.Views.AdminNotificationsPage"
             BackgroundColor="#0F1117">

    <ContentPage.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, *" Padding="20,50,20,20">

        <!-- RUBRIK -->
        <VerticalStackLayout Grid.Row="0" Spacing="6" Margin="0,0,0,20">
            <Label Text="Notiser"
                   FontSize="28" FontAttributes="Bold" TextColor="#F0F0F0"/>
            <BoxView HeightRequest="3" WidthRequest="50" Color="#E83B3B" HorizontalOptions="Start"/>
        </VerticalStackLayout>

        <!-- TILLBAKA-KNAPP -->
        <HorizontalStackLayout Grid.Row="1" Margin="0,0,0,20">
            <Border StrokeShape="RoundRectangle 10" Stroke="#2A2D38"
                    BackgroundColor="#1A1D27" HeightRequest="42" Padding="14,0">
                <Button Text="← Tillbaka" Clicked="OnBackClicked"
                        BackgroundColor="Transparent" TextColor="#E83B3B"
                        FontSize="13" FontAttributes="Bold" HeightRequest="42"/>
            </Border>
        </HorizontalStackLayout>

        <!-- TOM LISTA -->
        <VerticalStackLayout Grid.Row="2"
                             IsVisible="{Binding HasNoNotifications}"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
            <Label Text="Inga notiser just nu."
                   FontSize="18" FontAttributes="Bold"
                   TextColor="#F0F0F0" HorizontalOptions="Center"/>
            <Label Text="Notiser från användare visas här."
                   FontSize="14" TextColor="#8A8F9E" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- NOTISLISTA -->
        <CollectionView Grid.Row="2"
                        IsVisible="{Binding HasNoNotifications, Converter={StaticResource InverseBoolConverter}}"
                        ItemsSource="{Binding Notifications}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="entities:Notification">
                    <Grid Padding="0,0,0,10">
                        <Border StrokeShape="RoundRectangle 14"
                                Stroke="#2A2D38"
                                Padding="16,14">

                            <!-- Oläst = mörkröd bakgrund, läst = normal -->
                            <Border.BackgroundColor>
                                <Binding Path="IsRead">
                                    <Binding.Converter>
                                        <converters:InverseBoolConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Border.BackgroundColor>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNotificationTapped"/>
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto" ColumnSpacing="12">

                                <!-- Ikon -->
                                <Border Grid.Column="0" Grid.RowSpan="3"
                                        WidthRequest="40" HeightRequest="40"
                                        BackgroundColor="#E83B3B"
                                        StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent"
                                        VerticalOptions="Center">
                                    <Label Text="🔔" FontSize="20"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>

                                <!-- Från -->
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding FromUserId, StringFormat='Från: {0}'}"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="#E83B3B" CharacterSpacing="1.2"/>

                                <!-- Meddelande -->
                                <Label Grid.Row="1" Grid.Column="1"
                                       Text="{Binding Message}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="#F0F0F0" LineBreakMode="WordWrap"/>

                                <!-- Datum + oläst-badge -->
                                <HorizontalStackLayout Grid.Row="2" Grid.Column="1" Spacing="8">
                                    <Label Text="{Binding CreatedAt, StringFormat='{0:yyyy-MM-dd HH:mm}'}"
                                           FontSize="11" TextColor="#3A3D4A"/>
                                    <Border StrokeShape="RoundRectangle 6"
                                            BackgroundColor="#E83B3B"
                                            Padding="6,2"
                                            IsVisible="{Binding IsRead, Converter={StaticResource InverseBoolConverter}}">
                                        <Label Text="NY" FontSize="10"
                                               FontAttributes="Bold" TextColor="White"/>
                                    </Border>
                                </HorizontalStackLayout>

                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
