<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OlycksRapporteringV2.MAUI.Views.CreateReportPage"
             Title="Skapa Rapport">
    <ContentPage.Resources xmlns:converters="clr-namespace:OlycksRapporteringV2.MAUI.Converters">
        <converters:ErrorColorConverter x:Key="ErrorColorConverter"/>
    </ContentPage.Resources>
    <ScrollView>
        <VerticalStackLayout Padding="36,60,36,40"
                             Spacing="0">
            <Border StrokeShape="RoundRectangle 12"
Stroke="#2A2D38"
BackgroundColor="#1A1D27"
HeightRequest="48"
WidthRequest="130"
HorizontalOptions="End"
Margin="0,0,0,-60">
                <Button Text="← Tillbaka"
    Clicked="OnBackClicked"
    BackgroundColor="Transparent"
    TextColor="#E83B3B"
    FontSize="15"
    FontAttributes="Bold"
    HeightRequest="48"
    CornerRadius="12"/>
            </Border>
            <!-- Ikon -->
            <Border WidthRequest="80"
                    HeightRequest="80"
                    HorizontalOptions="Start"
                    Margin="0,0,0,32"
                    BackgroundColor="#E83B3B"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent">
                <Label Text="📝"
                       FontSize="36"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <!-- Rubrik -->
            <Label Text="Skapa&#10;rapport"
                   FontSize="42"
                   FontAttributes="Bold"
                   TextColor="#F0F0F0"
                   LineHeight="1.1"
                   Margin="0,0,0,16"/>

            <!-- Dekorativ linje -->
            <BoxView HeightRequest="3"
                     WidthRequest="60"
                     Color="#E83B3B"
                     HorizontalOptions="Start"
                     Margin="0,0,0,24"/>

            <Label Text="Fyll i uppgifterna nedan för att skicka in en incidentrapport."
                   FontSize="16"
                   TextColor="#8A8F9E"
                   LineHeight="1.6"
                   Margin="0,0,0,40"/>

            <!-- ═══ GRUNDLÄGGANDE INFORMATION ═══ -->
            <Label Text="GRUNDLÄGGANDE INFORMATION"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#E83B3B"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,16"/>

            <!-- Typ av olycka -->
            <Label Text="TYP AV OLYCKA"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A8F9E"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,8"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#2A2D38"
                    BackgroundColor="{Binding SelectedAccidentTypeHasError, Converter={StaticResource ErrorColorConverter}}"
                    Margin="0,0,0,16"
                    HeightRequest="54"
                    Padding="16,0"
                    WidthRequest="300"
                    HorizontalOptions="Start">
                <Picker 
                        ItemsSource="{Binding AccidentTypes}"
                        SelectedItem="{Binding SelectedAccidentType}"
                        TitleColor="#3A3D4A"
                        TextColor="#F0F0F0"
                        BackgroundColor="Transparent"
                        VerticalOptions="Center"
                        WidthRequest="250"/>
            </Border>

            <!-- Rapporttitel -->
            <Label Text="RAPPORTTITEL"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A8F9E"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,8"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#2A2D38"
                    BackgroundColor="{Binding ReportTitleHasError, Converter={StaticResource ErrorColorConverter}}"
                    Margin="0,0,0,16"
                    HeightRequest="54"
                    Padding="16,0"
                    WidthRequest="350"
                    HorizontalOptions="Start">
                <Entry Placeholder="Ange en titel för rapporten"
                       Text="{Binding ReportTitle}"
                       PlaceholderColor="#3A3D4A"
                       TextColor="#F0F0F0"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"
                       FontSize="15"/>
            </Border>

            <!-- Beskrivning -->
            <Label Text="BESKRIVNING"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A8F9E"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,8"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#2A2D38"
                    BackgroundColor="{Binding ReportDescriptionHasError, Converter={StaticResource ErrorColorConverter}}"
                    Margin="0,0,0,16"
                    Padding="16,12">
                <Editor Placeholder="Beskriv vad som hände..."
                        Text="{Binding ReportDescription}"
                        PlaceholderColor="#3A3D4A"
                        TextColor="#F0F0F0"
                        BackgroundColor="Transparent"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="120"
                        FontSize="15"/>
            </Border>
           
            <!-- Personer inblandade -->

            <Label Text="VEM RAPPORTEN HANDLAR OM"
        FontSize="11"
        FontAttributes="Bold"
        TextColor="#8A8F9E"
        CharacterSpacing="1.5"
        Margin="0,0,0,8"/>
            <Border StrokeShape="RoundRectangle 12"
         Stroke="#2A2D38"
         BackgroundColor="{Binding SelectedAffectedPersonTypeHasError, Converter={StaticResource ErrorColorConverter}}"
         Margin="0,0,0,16"
         HeightRequest="54"
         Padding="16,0"
         WidthRequest="300"
         HorizontalOptions="Start">
                <Picker 
             ItemsSource="{Binding AffectedPersonType}"
             SelectedItem="{Binding SelectedAffectedPersonType}"
             TitleColor="#3A3D4A"
             TextColor="#F0F0F0"
             BackgroundColor="Transparent"
             VerticalOptions="Center"
             WidthRequest="250"/>
            </Border>

            <Label Text="PERSONER INBLANDADE"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A8F9E"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,8"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#2A2D38"
                    BackgroundColor="#1A1D27"
                    Margin="0,0,0,16"
                    HeightRequest="54"
                    Padding="16,0">
                <Entry Placeholder="Namn eller antal inblandade"
                       Text="{Binding PeopleInvolved}"
                       PlaceholderColor="#3A3D4A"
                       TextColor="#F0F0F0"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"
                       FontSize="15"/>
            </Border>

            <!-- Plats -->
            <Label Text="PLATS"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A8F9E"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,8"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#2A2D38"
                    BackgroundColor="{Binding LocationHasError, Converter={StaticResource ErrorColorConverter}}"
                    Margin="0,0,0,16"
                    HeightRequest="54"
                    Padding="16,0">
                <Entry Placeholder="Var inträffade olyckan?"
                       Text="{Binding Location}"
                       PlaceholderColor="#3A3D4A"
                       TextColor="#F0F0F0"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"
                       FontSize="15"/>
            </Border>

            <!-- Tid -->
            <Label Text="TID VID OLYCKA"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A8F9E"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,8"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#2A2D38"
                    BackgroundColor="{Binding TimeHasError, Converter={StaticResource ErrorColorConverter}}"
                    Margin="0,0,0,36"
                    HeightRequest="54"
                    Padding="16,0">
                <Entry Placeholder="t.ex. 2025-06-01 14:30"
                       Text="{Binding TimeOfAccident}"
                       PlaceholderColor="#3A3D4A"
                       TextColor="#F0F0F0"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"
                       FontSize="15"/>
            </Border>

            <!-- ═══ SKADOR & ÅTGÄRDER ═══ -->
            <Label Text="SKADOR &amp; ÅTGÄRDER"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#E83B3B"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,16"/>

            <Border StrokeShape="RoundRectangle 14"
                    Stroke="#2A2D38"
                    BackgroundColor="#1A1D27"
                    Padding="20,16"
                    Margin="0,0,0,36">
                <VerticalStackLayout Spacing="0">

                    <!-- Materiell skada -->
                    <Label Text="MATERIELL SKADA"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#8A8F9E"
                           CharacterSpacing="1.5"
                           Margin="0,0,0,8"/>
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="#2A2D38"
                            BackgroundColor="#0F1117"
                            Margin="0,0,0,16"
                            HeightRequest="48"
                            Padding="14,0">
                        <Entry Placeholder="Beskriv materiell skada..."
                               Text="{Binding MaterialDamage}"
                               PlaceholderColor="#3A3D4A"
                               TextColor="#F0F0F0"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"
                               FontSize="15"/>
                    </Border>

                    <!-- Omedelbara åtgärder -->
                    <Label Text="OMEDELBARA ÅTGÄRDER"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#8A8F9E"
                           CharacterSpacing="1.5"
                           Margin="0,0,0,8"/>
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="#2A2D38"
                            BackgroundColor="#0F1117"
                            Margin="0,0,0,16"
                            HeightRequest="48"
                            Padding="14,0">
                        <Entry Placeholder="Vilka åtgärder vidtogs omedelbart?"
                               Text="{Binding ImmediateActions}"
                               PlaceholderColor="#3A3D4A"
                               TextColor="#F0F0F0"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"
                               FontSize="15"/>
                    </Border>

                    <!-- Förebyggande åtgärder -->
                    <Label Text="FÖREBYGGANDE ÅTGÄRDER"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#8A8F9E"
                           CharacterSpacing="1.5"
                           Margin="0,0,0,8"/>
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="#2A2D38"
                            BackgroundColor="#0F1117"
                            HeightRequest="48"
                            Padding="14,0">
                        <Entry Placeholder="Föreslagna förebyggande åtgärder..."
                               Text="{Binding PreventiveActions}"
                               PlaceholderColor="#3A3D4A"
                               TextColor="#F0F0F0"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"
                               FontSize="15"/>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- Skicka-knappen -->
            <Border StrokeShape="RoundRectangle 14"
                    Stroke="Transparent"
                    BackgroundColor="#E83B3B"
                    HeightRequest="56"
                    Margin="0,0,0,40">
                <Button Text="Skicka in rapport"
                        Command="{Binding CreateReportCommand}"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        HeightRequest="56"
                        CornerRadius="14"/>
            </Border>
            <Label Text="Vänligen fyll i alla obligatoriska fält korrekt."
       FontSize="13"
       TextColor="#E83B3B"
       HorizontalOptions="Center"
       Margin="0,8,0,0"
       IsVisible="{Binding HasAnyError}"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>