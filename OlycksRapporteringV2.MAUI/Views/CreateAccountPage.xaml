<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OlycksRapporteringV2.MAUI.Views.CreateAccount"
             Title="CreateAccount">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15" HorizontalOptions="Center">

            <!-- Header -->
            <Label 
            Text="Skapa ditt konto"
            FontSize="28"
            FontAttributes="Bold"
            HorizontalOptions="Center" />

            <Label Text="Personlig information" 
               FontSize="18" 
               FontAttributes="Bold"
               HorizontalOptions="Center" />

            <!-- Personlig info -->
            <Entry Text="{Binding EmployeeId}" 
               Placeholder="Ange ditt anställnings-ID" 
               WidthRequest="300" HorizontalOptions="Center"/>
            <Entry Text="{Binding Email}" 
               Placeholder="Email" 
               Keyboard="Email" 
               WidthRequest="300" HorizontalOptions="Center"/>
            <Entry Text="{Binding Password}" 
               Placeholder="Lösenord" 
               IsPassword="True" 
               WidthRequest="300" HorizontalOptions="Center"/>
            <Entry Text="{Binding HomeAdress}" 
               Placeholder="Hemadress" 
               WidthRequest="300" HorizontalOptions="Center"/>
            <Entry Text="{Binding SocialSecurityNumber}" 
               Placeholder="Personnummer" 
               Keyboard="Numeric" 
               WidthRequest="300" HorizontalOptions="Center"/>
            <Entry Text="{Binding PhoneNumber}" 
               Placeholder="Telefonnummer" 
               Keyboard="Telephone" 
               WidthRequest="300" HorizontalOptions="Center"/>
            <Entry Text="{Binding PersonalBank}" 
               Placeholder="Bank" 
               WidthRequest="300" HorizontalOptions="Center"/>

            <!-- Försäkringsbolag -->
            <Picker Title="Välj försäkringsbolag"
                ItemsSource="{Binding InsuranceCompanies}"
                SelectedItem="{Binding SelectedInsuranceCompany}"
                WidthRequest="300"
                HorizontalOptions="Center"/>

            <!-- Kontaktpersoner -->
            <Label Text="Kontaktpersoner" 
               FontSize="18" 
               FontAttributes="Bold" 
               HorizontalOptions="Center"/>

            <Frame BorderColor="LightGray" CornerRadius="10" Padding="10" WidthRequest="320" HorizontalOptions="Center">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Första kontaktpersonen" FontAttributes="Bold"/>
                    <Entry Text="{Binding ContactPerson1}" Placeholder="Namn" WidthRequest="280" HorizontalOptions="Center"/>
                    <Entry Text="{Binding ContactPerson1PhoneNumber}" Placeholder="Telefonnummer" WidthRequest="280" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="LightGray" CornerRadius="10" Padding="10" WidthRequest="320" HorizontalOptions="Center">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Andra kontaktpersonen" FontAttributes="Bold"/>
                    <Entry Text="{Binding ContactPerson2}" Placeholder="Namn" WidthRequest="280" HorizontalOptions="Center"/>
                    <Entry Text="{Binding ContactPerson2PhoneNumber}" Placeholder="Telefonnummer" WidthRequest="280" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Skapa-knappen -->
            <Button Text="Skapa användare"
                Command="{Binding CreateUserCommand}"
                BackgroundColor="#2196F3"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="10"
                HeightRequest="50"
                WidthRequest="200"
                HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>