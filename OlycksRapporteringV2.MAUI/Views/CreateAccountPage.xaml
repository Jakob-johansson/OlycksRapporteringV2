<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OlycksRapporteringV2.MAUI.Views.CreateAccount"
             Title="CreateAccount">
    <ScrollView>
        <VerticalStackLayout Padding="36,60,36,40"
                             Spacing="0">

            <!-- Ikon -->
            <Border WidthRequest="80"
                    HeightRequest="80"
                    HorizontalOptions="Start"
                    Margin="0,0,0,32"
                    BackgroundColor="#E83B3B"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent">
                <Label Text="✏️"
                       FontSize="36"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <!-- Rubrik -->
            <Label Text="Skapa&#10;konto"
                   FontSize="42"
                   FontAttributes="Bold"
                   TextColor="#F0F0F0"
                   LineHeight="1.1"
                   Margin="0,0,0,16"/>

            <!-- Dekorativ linje -->
            <BoxView HeightRequest="3"
                     WidthRequest="60"
                     Color="#E83B3B"
                     HorizontalOptions="Start"
                     Margin="0,0,0,24"/>

            <Label Text="Fyll i dina uppgifter för att skapa ett konto."
                   FontSize="16"
                   TextColor="#8A8F9E"
                   LineHeight="1.6"
                   Margin="0,0,0,40"/>

            <!-- ═══ PERSONLIG INFORMATION ═══ -->
            <Label Text="PERSONLIG INFORMATION"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#E83B3B"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,16"/>

            <!-- Anställnings-ID -->
            <Label Text="ANSTÄLLNINGS-ID"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A8F9E"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,8"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#2A2D38"
                    BackgroundColor="#1A1D27"
                    Margin="0,0,0,16"
                    HeightRequest="54"
                    Padding="16,0">
                <Entry Placeholder="Ange ditt anställnings-ID"
                       Text="{Binding EmployeeId}"
                       PlaceholderColor="#3A3D4A"
                       TextColor="#F0F0F0"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"
                       FontSize="15"/>
            </Border>

            <!-- Email -->
            <Label Text="EMAIL"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A8F9E"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,8"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#2A2D38"
                    BackgroundColor="#1A1D27"
                    Margin="0,0,0,16"
                    HeightRequest="54"
                    Padding="16,0">
                <Entry Placeholder="din@email.se"
                       Text="{Binding Email}"
                       Keyboard="Email"
                       PlaceholderColor="#3A3D4A"
                       TextColor="#F0F0F0"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"
                       FontSize="15"/>
            </Border>

            <!-- Lösenord -->
            <Label Text="LÖSENORD"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A8F9E"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,8"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#2A2D38"
                    BackgroundColor="#1A1D27"
                    Margin="0,0,0,16"
                    HeightRequest="54"
                    Padding="16,0">
                <Entry Placeholder="Välj ett lösenord"
                       Text="{Binding Password}"
                       IsPassword="True"
                       PlaceholderColor="#3A3D4A"
                       TextColor="#F0F0F0"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"
                       FontSize="15"/>
            </Border>

            <!-- Hemadress -->
            <Label Text="HEMADRESS"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A8F9E"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,8"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#2A2D38"
                    BackgroundColor="#1A1D27"
                    Margin="0,0,0,16"
                    HeightRequest="54"
                    Padding="16,0">
                <Entry Placeholder="Gatuadress, stad"
                       Text="{Binding HomeAdress}"
                       PlaceholderColor="#3A3D4A"
                       TextColor="#F0F0F0"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"
                       FontSize="15"/>
            </Border>

            <!-- Personnummer -->
            <Label Text="PERSONNUMMER"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A8F9E"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,8"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#2A2D38"
                    BackgroundColor="#1A1D27"
                    Margin="0,0,0,16"
                    HeightRequest="54"
                    Padding="16,0">
                <Entry Placeholder="ÅÅMMDD-XXXX"
                       Text="{Binding SocialSecurityNumber}"
                       Keyboard="Numeric"
                       PlaceholderColor="#3A3D4A"
                       TextColor="#F0F0F0"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"
                       FontSize="15"/>
            </Border>

            <!-- Telefonnummer -->
            <Label Text="TELEFONNUMMER"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A8F9E"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,8"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#2A2D38"
                    BackgroundColor="#1A1D27"
                    Margin="0,0,0,16"
                    HeightRequest="54"
                    Padding="16,0">
                <Entry Placeholder="07X-XXX XX XX"
                       Text="{Binding PhoneNumber}"
                       Keyboard="Telephone"
                       PlaceholderColor="#3A3D4A"
                       TextColor="#F0F0F0"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"
                       FontSize="15"/>
            </Border>

            <!-- Bank -->
            <Label Text="BANK"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A8F9E"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,8"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#2A2D38"
                    BackgroundColor="#1A1D27"
                    Margin="0,0,0,16"
                    HeightRequest="54"
                    Padding="16,0">
                <Entry Placeholder="Din bank"
                       Text="{Binding PersonalBank}"
                       PlaceholderColor="#3A3D4A"
                       TextColor="#F0F0F0"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"
                       FontSize="15"/>
            </Border>

            <!-- Försäkringsbolag -->
            <Label Text="FÖRSÄKRINGSBOLAG"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A8F9E"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,8"/>
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="#2A2D38"
                    BackgroundColor="#1A1D27"
                    Margin="0,0,0,36"
                    HeightRequest="54"
                    Padding="16,0">
                <Picker 
                        ItemsSource="{Binding InsuranceCompanies}"
                        SelectedItem="{Binding SelectedInsuranceCompany}"
                        TitleColor="#3A3D4A"
                        TextColor="#F0F0F0"
                        BackgroundColor="Transparent"
                        VerticalOptions="Center"/>
            </Border>

            <!-- ═══ KONTAKTPERSONER ═══ -->
            <Label Text="KONTAKTPERSONER"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#E83B3B"
                   CharacterSpacing="1.5"
                   Margin="0,0,0,16"/>

            <!-- Kontaktperson 1 -->
            <Border StrokeShape="RoundRectangle 14"
                    Stroke="#2A2D38"
                    BackgroundColor="#1A1D27"
                    Padding="20,16"
                    Margin="0,0,0,14">
                <VerticalStackLayout Spacing="0">
                    <Label Text="Första kontaktpersonen"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#F0F0F0"
                           Margin="0,0,0,14"/>

                    <Label Text="NAMN"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#8A8F9E"
                           CharacterSpacing="1.5"
                           Margin="0,0,0,8"/>
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="#2A2D38"
                            BackgroundColor="#0F1117"
                            Margin="0,0,0,12"
                            HeightRequest="48"
                            Padding="14,0">
                        <Entry Placeholder="För- och efternamn"
                               Text="{Binding ContactPerson1}"
                               PlaceholderColor="#3A3D4A"
                               TextColor="#F0F0F0"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"
                               FontSize="15"/>
                    </Border>

                    <Label Text="TELEFONNUMMER"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#8A8F9E"
                           CharacterSpacing="1.5"
                           Margin="0,0,0,8"/>
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="#2A2D38"
                            BackgroundColor="#0F1117"
                            HeightRequest="48"
                            Padding="14,0">
                        <Entry Placeholder="07X-XXX XX XX"
                               Text="{Binding ContactPerson1PhoneNumber}"
                               Keyboard="Telephone"
                               PlaceholderColor="#3A3D4A"
                               TextColor="#F0F0F0"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"
                               FontSize="15"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Kontaktperson 2 -->
            <Border StrokeShape="RoundRectangle 14"
                    Stroke="#2A2D38"
                    BackgroundColor="#1A1D27"
                    Padding="20,16"
                    Margin="0,0,0,36">
                <VerticalStackLayout Spacing="0">
                    <Label Text="Andra kontaktpersonen"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#F0F0F0"
                           Margin="0,0,0,14"/>

                    <Label Text="NAMN"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#8A8F9E"
                           CharacterSpacing="1.5"
                           Margin="0,0,0,8"/>
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="#2A2D38"
                            BackgroundColor="#0F1117"
                            Margin="0,0,0,12"
                            HeightRequest="48"
                            Padding="14,0">
                        <Entry Placeholder="För- och efternamn"
                               Text="{Binding ContactPerson2}"
                               PlaceholderColor="#3A3D4A"
                               TextColor="#F0F0F0"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"
                               FontSize="15"/>
                    </Border>

                    <Label Text="TELEFONNUMMER"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#8A8F9E"
                           CharacterSpacing="1.5"
                           Margin="0,0,0,8"/>
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="#2A2D38"
                            BackgroundColor="#0F1117"
                            HeightRequest="48"
                            Padding="14,0">
                        <Entry Placeholder="07X-XXX XX XX"
                               Text="{Binding ContactPerson2PhoneNumber}"
                               Keyboard="Telephone"
                               PlaceholderColor="#3A3D4A"
                               TextColor="#F0F0F0"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"
                               FontSize="15"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Skapa-knappen -->
            <Border StrokeShape="RoundRectangle 14"
                    Stroke="Transparent"
                    BackgroundColor="#E83B3B"
                    HeightRequest="56"
                    Margin="0,0,0,40">
                <Button Text="Skapa konto"
                        Command="{Binding CreateUserCommand}"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        HeightRequest="56"
                        CornerRadius="14"/>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>