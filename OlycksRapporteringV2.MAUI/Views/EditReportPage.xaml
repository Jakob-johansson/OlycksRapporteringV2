<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OlycksRapporteringV2.MAUI.Converters"
             x:Class="OlycksRapporteringV2.MAUI.Views.EditReportPage"
             BackgroundColor="#0F1117">

    <ContentPage.Resources>
        <converters:ErrorColorConverter x:Key="ErrorColorConverter"/>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="36,60,36,40" Spacing="0">

            <!-- Tillbaka-knapp -->
            <Border StrokeShape="RoundRectangle 12" Stroke="#2A2D38"
                    BackgroundColor="#1A1D27" HeightRequest="48" WidthRequest="130"
                    HorizontalOptions="Start" Margin="0,0,0,24">
                <Button Text="← Tillbaka" Clicked="OnBackClicked"
                        BackgroundColor="Transparent" TextColor="#E83B3B"
                        FontSize="15" FontAttributes="Bold" HeightRequest="48" CornerRadius="12"/>
            </Border>

            <!-- Ikon -->
            <Border WidthRequest="80" HeightRequest="80" HorizontalOptions="Start"
                    Margin="0,0,0,32" BackgroundColor="#E83B3B"
                    StrokeShape="RoundRectangle 20" Stroke="Transparent">
                <Label Text="✏️" FontSize="36" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <!-- Rubrik -->
            <Label Text="Redigera&#10;rapport" FontSize="42" FontAttributes="Bold"
                   TextColor="#F0F0F0" LineHeight="1.1" Margin="0,0,0,16"/>

            <!-- Dekorativ linje -->
            <BoxView HeightRequest="3" WidthRequest="60" Color="#E83B3B"
                     HorizontalOptions="Start" Margin="0,0,0,24"/>

            <Label Text="Tryck på redigera-knappen för att ändra ett fält."
                   FontSize="16" TextColor="#8A8F9E" LineHeight="1.6" Margin="0,0,0,40"/>

            <!-- ═══ GRUNDLÄGGANDE INFORMATION ═══ -->
            <Label Text="GRUNDLÄGGANDE INFORMATION" FontSize="11" FontAttributes="Bold"
                   TextColor="#E83B3B" CharacterSpacing="1.5" Margin="0,0,0,16"/>

            <Border StrokeShape="RoundRectangle 14" Stroke="#2A2D38"
                    BackgroundColor="#1A1D27" Padding="20,8" Margin="0,0,0,24">
                <VerticalStackLayout Spacing="0">

                    <!-- Rapporttitel -->
                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="0,12" MinimumHeightRequest="56">
                        <BoxView Grid.ColumnSpan="3" HeightRequest="1" Color="#2A2D38" VerticalOptions="End"/>
                        <Border Grid.Column="0" WidthRequest="32" HeightRequest="32" BackgroundColor="#2A2D38"
                                StrokeShape="RoundRectangle 8" Stroke="Transparent" VerticalOptions="Center" Margin="0,0,12,0">
                            <Label Text="📋" FontSize="15" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Rapporttitel" FontSize="12" TextColor="#8A8F9E"/>
                            <Label Text="{Binding ReportTitle}" FontSize="15" FontAttributes="Bold"
                                   TextColor="#F0F0F0" IsVisible="{Binding ReportTitleReadOnly}"/>
                            <Border StrokeShape="RoundRectangle 8" Stroke="#E83B3B" BackgroundColor="#0F1117"
                                    Padding="8,4" IsVisible="{Binding ReportTitleEditing}">
                                <Entry Text="{Binding ReportTitle}" TextColor="#F0F0F0"
                                       BackgroundColor="Transparent" FontSize="15"
                                       ReturnCommand="{Binding SaveReportTitleCommand}"/>
                            </Border>
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#2A2D38" StrokeShape="RoundRectangle 8"
                                Stroke="Transparent" Padding="12,6" VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEditReportTitleClicked"/>
                            </Border.GestureRecognizers>
                            <Label Text="Redigera" FontSize="12" TextColor="#E83B3B" FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                    <!-- Plats -->
                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="0,12" MinimumHeightRequest="56">
                        <BoxView Grid.ColumnSpan="3" HeightRequest="1" Color="#2A2D38" VerticalOptions="End"/>
                        <Border Grid.Column="0" WidthRequest="32" HeightRequest="32" BackgroundColor="#2A2D38"
                                StrokeShape="RoundRectangle 8" Stroke="Transparent" VerticalOptions="Center" Margin="0,0,12,0">
                            <Label Text="📍" FontSize="15" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Plats" FontSize="12" TextColor="#8A8F9E"/>
                            <Label Text="{Binding Location}" FontSize="15" FontAttributes="Bold"
                                   TextColor="#F0F0F0" IsVisible="{Binding LocationReadOnly}"/>
                            <Border StrokeShape="RoundRectangle 8" Stroke="#E83B3B" BackgroundColor="#0F1117"
                                    Padding="8,4" IsVisible="{Binding LocationEditing}">
                                <Entry Text="{Binding Location}" TextColor="#F0F0F0"
                                       BackgroundColor="Transparent" FontSize="15"
                                       ReturnCommand="{Binding SaveLocationCommand}"/>
                            </Border>
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#2A2D38" StrokeShape="RoundRectangle 8"
                                Stroke="Transparent" Padding="12,6" VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEditLocationClicked"/>
                            </Border.GestureRecognizers>
                            <Label Text="Redigera" FontSize="12" TextColor="#E83B3B" FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                    <!-- Tid -->
                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="0,12" MinimumHeightRequest="56">
                        <BoxView Grid.ColumnSpan="3" HeightRequest="1" Color="#2A2D38" VerticalOptions="End"/>
                        <Border Grid.Column="0" WidthRequest="32" HeightRequest="32" BackgroundColor="#2A2D38"
                                StrokeShape="RoundRectangle 8" Stroke="Transparent" VerticalOptions="Center" Margin="0,0,12,0">
                            <Label Text="🕐" FontSize="15" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Tid vid olycka" FontSize="12" TextColor="#8A8F9E"/>
                            <Label Text="{Binding TimeOfAccident}" FontSize="15" FontAttributes="Bold"
                                   TextColor="#F0F0F0" IsVisible="{Binding TimeReadOnly}"/>
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{Binding TimeHasError, Converter={StaticResource ErrorColorConverter}}"
                                    BackgroundColor="#0F1117" Padding="8,4" IsVisible="{Binding TimeEditing}">
                                <Entry Text="{Binding TimeOfAccident}" TextColor="#F0F0F0"
                                       BackgroundColor="Transparent" FontSize="15"
                                       Placeholder="yyyy-MM-dd HH:mm" PlaceholderColor="#3A3D4A"
                                       ReturnCommand="{Binding SaveTimeCommand}"/>
                            </Border>
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#2A2D38" StrokeShape="RoundRectangle 8"
                                Stroke="Transparent" Padding="12,6" VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEditTimeClicked"/>
                            </Border.GestureRecognizers>
                            <Label Text="Redigera" FontSize="12" TextColor="#E83B3B" FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                    <!-- Personer inblandade -->
                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="0,12" MinimumHeightRequest="56">
                        <Border Grid.Column="0" WidthRequest="32" HeightRequest="32" BackgroundColor="#2A2D38"
                                StrokeShape="RoundRectangle 8" Stroke="Transparent" VerticalOptions="Center" Margin="0,0,12,0">
                            <Label Text="👥" FontSize="15" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Personer inblandade" FontSize="12" TextColor="#8A8F9E"/>
                            <Label Text="{Binding PeopleInvolved}" FontSize="15" FontAttributes="Bold"
                                   TextColor="#F0F0F0" IsVisible="{Binding PeopleReadOnly}"/>
                            <Border StrokeShape="RoundRectangle 8" Stroke="#E83B3B" BackgroundColor="#0F1117"
                                    Padding="8,4" IsVisible="{Binding PeopleEditing}">
                                <Entry Text="{Binding PeopleInvolved}" TextColor="#F0F0F0"
                                       BackgroundColor="Transparent" FontSize="15"
                                       ReturnCommand="{Binding SavePeopleCommand}"/>
                            </Border>
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#2A2D38" StrokeShape="RoundRectangle 8"
                                Stroke="Transparent" Padding="12,6" VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEditPeopleClicked"/>
                            </Border.GestureRecognizers>
                            <Label Text="Redigera" FontSize="12" TextColor="#E83B3B" FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ═══ BESKRIVNING ═══ -->
            <Label Text="BESKRIVNING" FontSize="11" FontAttributes="Bold"
                   TextColor="#E83B3B" CharacterSpacing="1.5" Margin="0,0,0,16"/>

            <Border StrokeShape="RoundRectangle 14" Stroke="#2A2D38"
                    BackgroundColor="#1A1D27" Padding="20,8" Margin="0,0,0,24">
                <Grid ColumnDefinitions="*, Auto" Padding="0,12" MinimumHeightRequest="56">
                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                        <Label Text="{Binding ReportDescription}" FontSize="15"
                               TextColor="#F0F0F0" LineHeight="1.5"
                               IsVisible="{Binding ReportDescriptionReadOnly}"/>
                        <Border StrokeShape="RoundRectangle 8" Stroke="#E83B3B" BackgroundColor="#0F1117"
                                Padding="8,4" IsVisible="{Binding ReportDescriptionEditing}">
                            <Editor Text="{Binding ReportDescription}" TextColor="#F0F0F0"
                                    BackgroundColor="Transparent" FontSize="15"
                                    AutoSize="TextChanges" MinimumHeightRequest="80"/>
                        </Border>
                    </VerticalStackLayout>
                    <Border Grid.Column="1" BackgroundColor="#2A2D38" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="12,6" VerticalOptions="Start" Margin="12,0,0,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEditReportDescriptionClicked"/>
                        </Border.GestureRecognizers>
                        <Label Text="Redigera" FontSize="12" TextColor="#E83B3B" FontAttributes="Bold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ SKADOR & ÅTGÄRDER ═══ -->
            <Label Text="SKADOR &amp; ÅTGÄRDER" FontSize="11" FontAttributes="Bold"
                   TextColor="#E83B3B" CharacterSpacing="1.5" Margin="0,0,0,16"/>

            <Border StrokeShape="RoundRectangle 14" Stroke="#2A2D38"
                    BackgroundColor="#1A1D27" Padding="20,8" Margin="0,0,0,36">
                <VerticalStackLayout Spacing="0">

                    <!-- Materiell skada -->
                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="0,12" MinimumHeightRequest="56">
                        <BoxView Grid.ColumnSpan="3" HeightRequest="1" Color="#2A2D38" VerticalOptions="End"/>
                        <Border Grid.Column="0" WidthRequest="32" HeightRequest="32" BackgroundColor="#2A2D38"
                                StrokeShape="RoundRectangle 8" Stroke="Transparent" VerticalOptions="Center" Margin="0,0,12,0">
                            <Label Text="🔧" FontSize="15" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Materiell skada" FontSize="12" TextColor="#8A8F9E"/>
                            <Label Text="{Binding MaterialDamage}" FontSize="15" FontAttributes="Bold"
                                   TextColor="#F0F0F0" IsVisible="{Binding MaterialReadOnly}"/>
                            <Border StrokeShape="RoundRectangle 8" Stroke="#E83B3B" BackgroundColor="#0F1117"
                                    Padding="8,4" IsVisible="{Binding MaterialEditing}">
                                <Entry Text="{Binding MaterialDamage}" TextColor="#F0F0F0"
                                       BackgroundColor="Transparent" FontSize="15"
                                       ReturnCommand="{Binding SaveMaterialCommand}"/>
                            </Border>
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#2A2D38" StrokeShape="RoundRectangle 8"
                                Stroke="Transparent" Padding="12,6" VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEditMaterialClicked"/>
                            </Border.GestureRecognizers>
                            <Label Text="Redigera" FontSize="12" TextColor="#E83B3B" FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                    <!-- Omedelbara åtgärder -->
                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="0,12" MinimumHeightRequest="56">
                        <BoxView Grid.ColumnSpan="3" HeightRequest="1" Color="#2A2D38" VerticalOptions="End"/>
                        <Border Grid.Column="0" WidthRequest="32" HeightRequest="32" BackgroundColor="#2A2D38"
                                StrokeShape="RoundRectangle 8" Stroke="Transparent" VerticalOptions="Center" Margin="0,0,12,0">
                            <Label Text="⚡" FontSize="15" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Omedelbara åtgärder" FontSize="12" TextColor="#8A8F9E"/>
                            <Label Text="{Binding ImmediateActions}" FontSize="15" FontAttributes="Bold"
                                   TextColor="#F0F0F0" IsVisible="{Binding ImmediateReadOnly}"/>
                            <Border StrokeShape="RoundRectangle 8" Stroke="#E83B3B" BackgroundColor="#0F1117"
                                    Padding="8,4" IsVisible="{Binding ImmediateEditing}">
                                <Entry Text="{Binding ImmediateActions}" TextColor="#F0F0F0"
                                       BackgroundColor="Transparent" FontSize="15"
                                       ReturnCommand="{Binding SaveImmediateCommand}"/>
                            </Border>
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#2A2D38" StrokeShape="RoundRectangle 8"
                                Stroke="Transparent" Padding="12,6" VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEditImmediateClicked"/>
                            </Border.GestureRecognizers>
                            <Label Text="Redigera" FontSize="12" TextColor="#E83B3B" FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                    <!-- Förebyggande åtgärder -->
                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="0,12" MinimumHeightRequest="56">
                        <Border Grid.Column="0" WidthRequest="32" HeightRequest="32" BackgroundColor="#2A2D38"
                                StrokeShape="RoundRectangle 8" Stroke="Transparent" VerticalOptions="Center" Margin="0,0,12,0">
                            <Label Text="🛡️" FontSize="15" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Förebyggande åtgärder" FontSize="12" TextColor="#8A8F9E"/>
                            <Label Text="{Binding PreventiveActions}" FontSize="15" FontAttributes="Bold"
                                   TextColor="#F0F0F0" IsVisible="{Binding PreventiveReadOnly}"/>
                            <Border StrokeShape="RoundRectangle 8" Stroke="#E83B3B" BackgroundColor="#0F1117"
                                    Padding="8,4" IsVisible="{Binding PreventiveEditing}">
                                <Entry Text="{Binding PreventiveActions}" TextColor="#F0F0F0"
                                       BackgroundColor="Transparent" FontSize="15"
                                       ReturnCommand="{Binding SavePreventiveCommand}"/>
                            </Border>
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#2A2D38" StrokeShape="RoundRectangle 8"
                                Stroke="Transparent" Padding="12,6" VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEditPreventiveClicked"/>
                            </Border.GestureRecognizers>
                            <Label Text="Redigera" FontSize="12" TextColor="#E83B3B" FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Spara-knapp -->
            <Border StrokeShape="RoundRectangle 14" Stroke="Transparent"
                    BackgroundColor="#E83B3B" HeightRequest="56" Margin="0,0,0,40">
                <Button Text="Spara ändringar"
                        Command="{Binding SaveAllCommand}"
                        Clicked="OnClickedGoBack"
                        BackgroundColor="Transparent" TextColor="White"
                        FontSize="16" FontAttributes="Bold"
                        HeightRequest="56" CornerRadius="14"/>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
