<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OlycksRapporteringV2.MAUI.Converters"
             xmlns:models="clr-namespace:OlycksRapporteringV2.MAUI.Models"
             x:Class="OlycksRapporteringV2.MAUI.Views.AdminShowAllReportsPage"
             BackgroundColor="#0F1117">

    <ContentPage.Resources>
        <converters:ErrorColorConverter x:Key="ErrorColorConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <converters:EqualToConverter x:Key="EqualToConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, *"
          Padding="20,50,20,20">

        <!-- RUBRIK -->
        <VerticalStackLayout Grid.Row="0" Spacing="6" Margin="0,0,0,20">
            <Label Text="Alla rapporter"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#F0F0F0"/>
            <BoxView HeightRequest="3" WidthRequest="50" Color="#E83B3B" HorizontalOptions="Start"/>
        </VerticalStackLayout>

        <!-- STATUSFILTER -->
        <VerticalStackLayout Grid.Row="1" Margin="0,0,0,16" Spacing="10">
            <Label Text="FILTRERA PÅ STATUS"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#E83B3B"
                   CharacterSpacing="1.5"/>

            <FlexLayout Wrap="Wrap"
                        JustifyContent="Start"
                        AlignItems="Start">

                <Border StrokeShape="RoundRectangle 20" Stroke="{Binding ActiveFilter, Converter={StaticResource EqualToConverter},ConverterParameter=''}"
                        BackgroundColor="#1A1D27" Padding="4,0" Margin="0,0,10,10">
                    <Button Text="● Alla" Clicked="OnFilterAllClicked"
                            BackgroundColor="Transparent" TextColor="#F0F0F0"
                            FontSize="13" HeightRequest="38"/>
                </Border>

                <Border StrokeShape="RoundRectangle 20" Stroke="{Binding ActiveFilter, Converter={StaticResource EqualToConverter},ConverterParameter='Created'}"
                        BackgroundColor="#1A1D27" Padding="4,0" Margin="0,0,10,10">
                    <Button Text="● Created" Clicked="OnFilterCreatedClicked"
                            BackgroundColor="Transparent" TextColor="#8A8F9E"
                            FontSize="13" HeightRequest="38"/>
                </Border>

                <Border StrokeShape="RoundRectangle 20" Stroke="{Binding ActiveFilter, Converter={StaticResource EqualToConverter},ConverterParameter='Pending'}"
                        BackgroundColor="#1A1D27" Padding="4,0" Margin="0,0,10,10">
                    <Button Text="● Pending" Clicked="OnFilterPendingClicked"
                            BackgroundColor="Transparent" TextColor="#F0A83B"
                            FontSize="13" HeightRequest="38"/>
                </Border>

                <Border StrokeShape="RoundRectangle 20" Stroke="{Binding ActiveFilter, Converter={StaticResource EqualToConverter},ConverterParameter='UnderReview'}"
                        BackgroundColor="#1A1D27" Padding="4,0" Margin="0,0,10,10">
                    <Button Text="● Under Review" Clicked="OnFilterUnderReviewClicked"
                            BackgroundColor="Transparent" TextColor="#3B9EE8"
                            FontSize="13" HeightRequest="38"/>
                </Border>

                <Border StrokeShape="RoundRectangle 20" Stroke="{Binding ActiveFilter, Converter={StaticResource EqualToConverter},ConverterParameter='Approved'}"
                        BackgroundColor="#1A1D27" Padding="4,0" Margin="0,0,10,10">
                    <Button Text="● Approved" Clicked="OnFilterApprovedClicked"
                            BackgroundColor="Transparent" TextColor="#3BE87A"
                            FontSize="13" HeightRequest="38"/>
                </Border>

                <Border StrokeShape="RoundRectangle 20" Stroke="{Binding ActiveFilter, Converter={StaticResource EqualToConverter},ConverterParameter='Rejected'}"
                        BackgroundColor="#1A1D27" Padding="4,0" Margin="0,0,10,10">
                    <Button Text="● Rejected" Clicked="OnFilterRejectedClicked"
                            BackgroundColor="Transparent" TextColor="#E83B3B"
                            FontSize="13" HeightRequest="38"/>
                </Border>

            </FlexLayout>
        </VerticalStackLayout>

        <!-- SNABBKNAPPAR -->
        <HorizontalStackLayout Grid.Row="2" Spacing="10" Margin="0,0,0,20">

            <!-- Tillbaka -->
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="#2A2D38"
                    BackgroundColor="#1A1D27"
                    HeightRequest="42"
                    Padding="14,0">
                <Button Text="← Tillbaka"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="#E83B3B"
                        FontSize="13"
                        FontAttributes="Bold"
                        HeightRequest="42"/>
            </Border>

            <!-- Välj för radering -->
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="#2A2D38"
                    BackgroundColor="{Binding SelectModeActive, Converter={StaticResource ErrorColorConverter}}"
                    HeightRequest="42"
                    Padding="14,0">
                <Button Text="🗑 Välj"
                        Clicked="OnSelectModeClicked"
                        BackgroundColor="Transparent"
                        TextColor="#F0F0F0"
                        FontSize="13"
                        HeightRequest="42"/>
            </Border>

            <!-- Radera valda -->
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="#E83B3B"
                    BackgroundColor="#1A1D27"
                    HeightRequest="42"
                    Padding="14,0"
                    IsVisible="{Binding SelectModeActive}">
                <Button Text="Radera valda"
                        Clicked="OnDeleteSelectedClicked"
                        BackgroundColor="Transparent"
                        TextColor="#E83B3B"
                        FontSize="13"
                        FontAttributes="Bold"
                        HeightRequest="42"/>
            </Border>

        </HorizontalStackLayout>

        <!-- TOM LISTA -->
        <VerticalStackLayout Grid.Row="4"
                             IsVisible="{Binding HasNoReports}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="8">
            <Label Text="Inga rapporter hittades."
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#F0F0F0"
                   HorizontalOptions="Center"/>
            <Label Text="Inga rapporter har skickats in ännu."
                   FontSize="14"
                   TextColor="#8A8F9E"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- RAPPORTLISTA -->
        <CollectionView Grid.Row="4"
                        IsVisible="{Binding HasNoReports, Converter={StaticResource InverseBoolConverter}}"
                        ItemsSource="{Binding Reports}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SelectableReport">
                    <Grid Padding="0,0,0,8">
                        <Border StrokeShape="RoundRectangle 12"
                                Stroke="#2A2D38"
                                BackgroundColor="{Binding CardColor}"
                                Padding="14,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnReportTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto, Auto">

                                <!-- Status -->
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Report.Status}"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#E83B3B"
                                       CharacterSpacing="1.2"/>

                                <!-- Kryssruta -->
                                <Label Grid.Row="0" Grid.Column="1"
                                       Grid.RowSpan="4"
                                       Text="{Binding CheckboxIcon}"
                                       FontSize="22"
                                       TextColor="#E83B3B"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                   Path=BindingContext.SelectModeActive}"/>

                                <!-- Titel -->
                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="{Binding Report.ReportTitle}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#F0F0F0"/>

                                <!-- Skapad av -->
                                <Label Grid.Row="2" Grid.Column="0"
                                       Text="{Binding CreatedByName, StringFormat='Skapad av: {0}'}"
                                       FontSize="11"
                                       TextColor="#8A8F9E"/>

                                <!-- Datum + beskrivning -->
                                <HorizontalStackLayout Grid.Row="3" Grid.Column="0" Spacing="8">
                                    <Label Text="{Binding Report.CreatedAt, StringFormat='{0:yyyy-MM-dd}'}"
                                           FontSize="11"
                                           TextColor="#3A3D4A"/>
                                    <Label Text="{Binding ShortDescription}"
                                           FontSize="11"
                                           TextColor="#8A8F9E"
                                           LineBreakMode="TailTruncation"/>
                                </HorizontalStackLayout>

                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
